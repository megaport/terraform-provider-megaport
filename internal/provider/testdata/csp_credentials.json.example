{
  "comment": "Copy this file to csp_credentials.json and fill in real staging keys. Alternatively, set CSP_CREDENTIALS_JSON as an env var with the JSON contents. Keys are consumed after use — run cleanup-test-resources.sh between runs to free Azure port+vlan slots.",
  "azure_service_keys": [
    "REPLACE_WITH_AZURE_SERVICE_KEY"
  ],
  "azure_service_keys_with_peers": [
    "REPLACE_WITH_AZURE_SERVICE_KEY_WITH_PEERS"
  ],
  "oracle_virtual_circuit_ids": [
    "ocid1.virtualcircuit.oc1.REGION.REPLACE_WITH_ORACLE_VCID"
  ],
  "google_pairing_keys": [
    "REPLACE_WITH_GCP_PAIRING_KEY/region/1"
  ]
}
